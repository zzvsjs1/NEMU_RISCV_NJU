--- a/src/image/ONScripter_image.cpp
+++ b/src/image/ONScripter_image.cpp
@@ -29 +64,36 @@
+#ifdef __NAVY__
+static bool isNavyOptionalMissingImage(const char *filename)
+{
+    const char *base = filename;
+    const char *slash = strrchr(filename, '/');
+    const char *backslash = strrchr(filename, '\\');
+
+    if (slash && slash + 1 > base)
+        base = slash + 1;
+    if (backslash && backslash + 1 > base)
+        base = backslash + 1;
+
+    if (!strcmp(base, "uoncur.bmp") || !strcmp(base, "uoffcur.bmp") ||
+        !strcmp(base, "doncur.bmp") || !strcmp(base, "doffcur.bmp") ||
+        !strcmp(base, "cursor0.bmp") || !strcmp(base, "cursor1.bmp"))
+    {
+        return true;
+    }
+
+    /*
+     * Old save files can pre-date Navy screenshot support.  In that case the
+     * DAT is still loadable, but the slot thumbnail is missing until the slot
+     * is saved again.
+     */
+    if ((!strncmp(filename, "savedata/", 9) || !strncmp(filename, "savedata\\", 9)) &&
+        !strncmp(base, "save", 4))
+    {
+        const char *ext = strrchr(base, '.');
+        return ext != NULL && !strcmp(ext, ".bmp");
+    }
+
+    return false;
+}
+#endif
