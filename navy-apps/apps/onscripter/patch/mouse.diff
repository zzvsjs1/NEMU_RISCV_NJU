+#ifdef __NAVY__
+void ONScripter::hideNavyMouseCursor()
+{
+    if (!last_mouse_cursor_visible) return;
+
+    /*
+     * The fake cursor is only an overlay.  showNavyMouseCursor() restores
+     * screen_surface immediately after pushing the cursor pixels to the
+     * framebuffer, so this update copies the clean game pixels back over the
+     * previous cursor position.  Without this second framebuffer update, every
+     * old 8x8 cursor remains visible until a later game redraw happens to
+     * touch the same rectangle.
+     */
+    SDL_UpdateRect(screen_surface, last_mouse_cursor_rect.x,
+                   last_mouse_cursor_rect.y, last_mouse_cursor_rect.w,
+                   last_mouse_cursor_rect.h);
+    last_mouse_cursor_visible = false;
+}
+
+void ONScripter::showNavyMouseCursor()
+{
+    hideNavyMouseCursor();
+
+    const int mouse_x = current_button_state.x;
+    const int mouse_y = current_button_state.y;
+    if (mouse_x < 0 || mouse_y < 0 ||
+        mouse_x + 8 > screen_surface->w ||
+        mouse_y + 8 > screen_surface->h) {
+        return;
+    }
+
+    SDL_Rect mouse_rect = { .x = 0, .y = 0, .w = 8, .h = 8 };
+    mouse_rect.x = mouse_x;
+    mouse_rect.y = mouse_y;
+
+    /*
+     * Keep screen_surface as the game-only backing store.  We temporarily
+     * blit the cursor, update the physical framebuffer, then restore the saved
+     * pixels in memory.  The next hideNavyMouseCursor() can then repaint the
+     * old framebuffer rectangle from clean memory.
+     */
+    SDL_BlitSurface(screen_surface, &mouse_rect, mouse_save_surface, NULL);
+    SDL_BlitSurface(mouse_surface, NULL, screen_surface, &mouse_rect);
+    SDL_UpdateRect(screen_surface, mouse_rect.x, mouse_rect.y, mouse_rect.w, mouse_rect.h);
+    SDL_BlitSurface(mouse_save_surface, NULL, screen_surface, &mouse_rect);
+
+    last_mouse_cursor_rect = mouse_rect;
+    last_mouse_cursor_visible = true;
+}
+#endif
