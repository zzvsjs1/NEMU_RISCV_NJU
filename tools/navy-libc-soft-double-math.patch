Subject: [PATCH] Add Navy soft double math

---
 src/math/math.c | 847 ++++++++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 824 insertions(+), 23 deletions(-)

diff --git a/src/math/math.c b/src/math/math.c
index a57f7de..0d7a730 100644
--- a/src/math/math.c
+++ b/src/math/math.c
@@ -1,44 +1,845 @@
-#include <math.h>
-#include <assert.h>
+#include <stdint.h>
 
-// Navy does not support floating point
+/*
+ * Small standalone IEEE-754 binary64 math subset for Navy.
+ *
+ * Why this file exists:
+ *   Navy normally builds RISC-V32 applications with -march=rv32im_zicsr and
+ *   -mabi=ilp32.  That ABI is a soft-float ABI: float and double values are
+ *   passed through integer registers and memory as raw IEEE-754 bit patterns.
+ *   The compiler-rt archive provides primitive operations such as __muldf3 and
+ *   __divdf3, but it does not provide higher-level libm functions such as
+ *   sin(), cos(), tan(), sqrt(), floor(), or ceil().
+ *
+ * The previous implementation deliberately asserted for all of those
+ * functions.  ONScripter uses trigonometry and square root for script commands,
+ * affine sprites, quake effects, and plug-in-style visual effects, so the
+ * assertion path crashes real games.  This file provides enough libm behaviour
+ * for that environment without requiring RISC-V F/D floating-point registers.
+ *
+ * Accuracy and scope:
+ *   - fabs(), floor(), ceil(), and round() are exact for ordinary IEEE-754
+ *     binary64 inputs.
+ *   - sqrt() uses a digit-by-digit integer algorithm over the binary mantissa.
+ *     It is intentionally slower than a hardware instruction but avoids an FPU.
+ *   - sin(), cos(), tan(), log(), exp(), and pow() are compact approximations.
+ *     They are suitable for this embedded runtime and ONScripter's visual
+ *     effects, but they are not a formally correctly-rounded full libm.
+ *
+ * Implementation style:
+ *   The bit conversion helpers use a union.  GCC supports this style of
+ *   type-punning, and it avoids pulling memcpy() into low-level math routines.
+ *   The rest of the code uses ordinary integer and soft-double operations, so
+ *   the RV32 output must not contain flw/fsw/fadd/fmul/fdiv/fsqrt/fcvt/etc.
+ */
 
-double fabs(double x) {
-  assert(0);
+#define SM_SIGN_MASK UINT64_C(0x8000000000000000)
+#define SM_ABS_MASK  UINT64_C(0x7fffffffffffffff)
+#define SM_EXP_MASK  UINT64_C(0x7ff0000000000000)
+#define SM_FRAC_MASK UINT64_C(0x000fffffffffffff)
+#define SM_QNAN_BITS UINT64_C(0x7ff8000000000000)
+#define SM_PINF_BITS UINT64_C(0x7ff0000000000000)
+
+typedef union {
+  double f;
+  uint64_t u;
+} sm_f64_bits;
+
+static uint64_t sm_asuint64(double x)
+{
+  sm_f64_bits v;
+  v.f = x;
+  return v.u;
+}
+
+static double sm_asdouble(uint64_t u)
+{
+  sm_f64_bits v;
+  v.u = u;
+  return v.f;
+}
+
+static double sm_nan(void)
+{
+  return sm_asdouble(SM_QNAN_BITS);
+}
+
+static double sm_inf_with_sign(uint64_t sign)
+{
+  return sm_asdouble((sign & SM_SIGN_MASK) | SM_PINF_BITS);
+}
+
+static int sm_is_nan_bits(uint64_t u)
+{
+  return (u & SM_EXP_MASK) == SM_EXP_MASK && (u & SM_FRAC_MASK) != 0;
+}
+
+static int sm_is_inf_bits(uint64_t u)
+{
+  return (u & SM_ABS_MASK) == SM_PINF_BITS;
+}
+
+static double sm_make_signed_zero(uint64_t sign)
+{
+  return sm_asdouble(sign & SM_SIGN_MASK);
+}
+
+double fabs(double x)
+{
+  return sm_asdouble(sm_asuint64(x) & SM_ABS_MASK);
+}
+
+/* ------------------------------------------------------------------------- */
+/* floor / ceil / round                                                      */
+/* ------------------------------------------------------------------------- */
+
+double floor(double x)
+{
+  uint64_t u = sm_asuint64(x);
+  uint64_t sign = u & SM_SIGN_MASK;
+  int exp_bits = (int)((u >> 52) & 0x7ff);
+  int e = exp_bits - 1023;
+
+  if (exp_bits == 0x7ff)
+    return x + x;
+
+  if (e < 0) {
+    if ((u & SM_ABS_MASK) == 0)
+      return x;
+    return sign ? -1.0 : 0.0;
+  }
+
+  if (e >= 52)
+    return x;
+
+  /*
+   * The low 52-e mantissa bits are the fractional part.  Clearing them rounds
+   * toward zero.  For negative non-integral numbers, add one integer unit
+   * before clearing so the result moves toward negative infinity instead.
+   */
+  uint64_t mask = (UINT64_C(1) << (52 - e)) - 1;
+  if ((u & mask) == 0)
+    return x;
+
+  if (sign)
+    u += UINT64_C(1) << (52 - e);
+  u &= ~mask;
+  return sm_asdouble(u);
+}
+
+double ceil(double x)
+{
+  uint64_t u = sm_asuint64(x);
+  uint64_t sign = u & SM_SIGN_MASK;
+  int exp_bits = (int)((u >> 52) & 0x7ff);
+  int e = exp_bits - 1023;
+
+  if (exp_bits == 0x7ff)
+    return x + x;
+
+  if (e < 0) {
+    if ((u & SM_ABS_MASK) == 0)
+      return x;
+    return sign ? sm_make_signed_zero(SM_SIGN_MASK) : 1.0;
+  }
+
+  if (e >= 52)
+    return x;
+
+  /*
+   * ceil() is the mirror of floor(): positive non-integral values need one
+   * integer unit added before the fractional bits are removed, while negative
+   * values can simply be rounded toward zero.
+   */
+  uint64_t mask = (UINT64_C(1) << (52 - e)) - 1;
+  if ((u & mask) == 0)
+    return x;
+
+  if (!sign)
+    u += UINT64_C(1) << (52 - e);
+  u &= ~mask;
+  return sm_asdouble(u);
+}
+
+double round(double x)
+{
+  uint64_t u = sm_asuint64(x);
+  uint64_t sign = u & SM_SIGN_MASK;
+  int exp_bits = (int)((u >> 52) & 0x7ff);
+  int e = exp_bits - 1023;
+
+  if (exp_bits == 0x7ff)
+    return x + x;
+
+  if (e < 0) {
+    if ((u & SM_ABS_MASK) == 0)
+      return x;
+    if (e < -1)
+      return sm_make_signed_zero(sign);
+    return sign ? -1.0 : 1.0; /* |x| is in [0.5, 1). */
+  }
+
+  if (e >= 52)
+    return x;
+
+  uint64_t mask = (UINT64_C(1) << (52 - e)) - 1;
+  uint64_t frac = u & mask;
+  if (frac == 0)
+    return x;
+
+  uint64_t half = UINT64_C(1) << (51 - e);
+  u &= ~mask;
+  if (frac >= half)
+    u += UINT64_C(1) << (52 - e); /* C round() rounds halfway cases away from zero. */
+
+  return sm_asdouble(u);
+}
+
+/* ------------------------------------------------------------------------- */
+/* sqrt                                                                      */
+/* ------------------------------------------------------------------------- */
+
+double sqrt(double x)
+{
+  uint64_t u = sm_asuint64(x);
+  uint64_t ax = u & SM_ABS_MASK;
+  uint64_t ix, q, s, r, t;
+  int exp_bits, e, i;
+
+  if ((u & SM_EXP_MASK) == SM_EXP_MASK) {
+    if (u & SM_SIGN_MASK)
+      return sm_nan();
+    return x * x + x;          /* sqrt(+Inf)=+Inf; NaN stays NaN. */
+  }
+
+  if (u & SM_SIGN_MASK) {
+    if (ax == 0)
+      return x;                /* sqrt(-0) = -0. */
+    return sm_nan();
+  }
+
+  if (ax == 0)
+    return x;
+
+  exp_bits = (int)((u >> 52) & 0x7ff);
+  ix = u & SM_FRAC_MASK;
+
+  if (exp_bits == 0) {
+    /*
+     * Subnormal numbers do not have the hidden leading mantissa bit.  Shift
+     * left until that bit appears, and compensate by lowering the effective
+     * exponent.  This keeps the later square-root loop identical for normal
+     * and subnormal inputs.
+     */
+    for (i = 0; (ix & UINT64_C(0x0010000000000000)) == 0; i++)
+      ix <<= 1;
+    exp_bits = 1 - i;
+  } else {
+    ix |= UINT64_C(0x0010000000000000);
+  }
+
+  e = exp_bits - 1023;
+
+  /*
+   * sqrt(m * 2^e) = sqrt(m) * 2^(e/2).  If e is odd, double the mantissa first
+   * so that the final exponent division is exact.
+   */
+  if (e & 1)
+    ix <<= 1;
+  e >>= 1;
+  ix <<= 1;
+
+  /*
+   * Digit-by-digit square root in base 2.  q accumulates the root bits, s is
+   * the trial divisor, and r walks from the highest candidate bit down to zero.
+   * This is slower than Newton iteration, but it is deterministic, uses only
+   * integer operations on the mantissa, and avoids dependency on another sqrt.
+   */
+  q = 0;
+  s = 0;
+  r = UINT64_C(1) << 53;
+
+  while (r != 0) {
+    t = s + r;
+    if (t <= ix) {
+      s = t + r;
+      ix -= t;
+      q += r;
+    }
+    ix <<= 1;
+    r >>= 1;
+  }
+
+  if (ix != 0)
+    q += q & 1;                /* Round to nearest-even in the usual mode. */
+
+  return sm_asdouble((q >> 1) + ((uint64_t)(e + 1022) << 52));
+}
+
+/* ------------------------------------------------------------------------- */
+/* log / exp helper / pow                                                    */
+/* ------------------------------------------------------------------------- */
+
+static const double SM_LN2_HI = 6.93147180369123816490e-01;
+static const double SM_LN2_LO = 1.90821492927058770002e-10;
+static const double SM_INV_LN2 = 1.44269504088896340736e+00;
+static const double SM_LOG_DBL_MAX = 7.09782712893383996732e+02;
+static const double SM_LOG_DBL_TRUE_MIN_HALF = -7.45133219101941108420e+02;
+
+static double sm_pow2_int(int n)
+{
+  if (n > 1023)
+    return sm_inf_with_sign(0);
+  if (n >= -1022)
+    return sm_asdouble(((uint64_t)(n + 1023)) << 52);
+  if (n >= -1074)
+    return sm_asdouble(UINT64_C(1) << (n + 1074));
+  return 0.0;
+}
+
+static double sm_scalbn(double x, int n)
+{
+  if (x == 0.0)
+    return x;
+
+  while (n > 1023) {
+    x *= sm_pow2_int(1023);
+    n -= 1023;
+    if (sm_is_inf_bits(sm_asuint64(x)))
+      return x;
+  }
+  while (n < -1022) {
+    x *= sm_pow2_int(-1022);
+    n += 1022;
+    if (x == 0.0)
+      return x;
+  }
+  return x * sm_pow2_int(n);
+}
+
+static double sm_exp(double x)
+{
+  uint64_t ux = sm_asuint64(x);
+  if (sm_is_nan_bits(ux))
+    return x + x;
+  if (x > SM_LOG_DBL_MAX)
+    return sm_inf_with_sign(0);
+  if (x < SM_LOG_DBL_TRUE_MIN_HALF)
+    return 0.0;
+  if (sm_is_inf_bits(ux))
+    return (ux & SM_SIGN_MASK) ? 0.0 : sm_inf_with_sign(0);
+
+  int n = (int)(x * SM_INV_LN2 + (x >= 0.0 ? 0.5 : -0.5));
+  double dn = (double)n;
+  double r = (x - dn * SM_LN2_HI) - dn * SM_LN2_LO;
+
+  /*
+   * exp(x) = 2^n * exp(r), with r constrained to roughly [-ln(2)/2, ln(2)/2].
+   * The polynomial is a compact Taylor/Horner approximation for exp(r)-1 over
+   * that interval.  Splitting ln(2) keeps the reduction error small enough for
+   * this embedded libm subset.
+   */
+  double p = 1.56192069685862264622e-16;
+  p = 2.81145725434552076320e-15 + r * p;
+  p = 4.77947733238738529744e-14 + r * p;
+  p = 7.64716373181981647590e-13 + r * p;
+  p = 1.14707455977297247139e-11 + r * p;
+  p = 1.60590438368216145994e-10 + r * p;
+  p = 2.08767569878680989792e-09 + r * p;
+  p = 2.50521083854417187751e-08 + r * p;
+  p = 2.75573192239858906526e-07 + r * p;
+  p = 2.75573192239858906526e-06 + r * p;
+  p = 2.48015873015873015873e-05 + r * p;
+  p = 1.98412698412698412698e-04 + r * p;
+  p = 1.38888888888888888889e-03 + r * p;
+  p = 8.33333333333333333333e-03 + r * p;
+  p = 4.16666666666666666667e-02 + r * p;
+  p = 1.66666666666666666667e-01 + r * p;
+  p = 5.00000000000000000000e-01 + r * p;
+  p = 1.00000000000000000000e+00 + r * p;
+
+  return sm_scalbn(1.0 + r * p, n);
+}
+
+double log(double x)
+{
+  uint64_t ux = sm_asuint64(x);
+  uint64_t ax = ux & SM_ABS_MASK;
+
+  if (sm_is_nan_bits(ux))
+    return x + x;
+  if (ax == 0)
+    return -sm_inf_with_sign(0);
+  if (ux & SM_SIGN_MASK)
+    return sm_nan();
+  if (ax == SM_PINF_BITS)
+    return x;
+
+  int exp_bits = (int)((ux >> 52) & 0x7ff);
+  int k;
+  uint64_t frac;
+
+  if (exp_bits == 0) {
+    /* Scale subnormal values into the normal range before extracting mantissa. */
+    x *= sm_pow2_int(54);
+    ux = sm_asuint64(x);
+    exp_bits = (int)((ux >> 52) & 0x7ff);
+    k = exp_bits - 1023 - 54;
+    frac = ux & SM_FRAC_MASK;
+  } else {
+    k = exp_bits - 1023;
+    frac = ux & SM_FRAC_MASK;
+  }
+
+  double m = sm_asdouble(UINT64_C(0x3ff0000000000000) | frac);
+
+  /*
+   * Reduce m to [sqrt(1/2), sqrt(2)].  Then log(m) can be expressed through
+   * z=(m-1)/(m+1), where |z| is small and the atanh series converges quickly:
+   *   log(m) = 2*z*(1 + z^2/3 + z^4/5 + ...).
+   */
+  if (m > 1.41421356237309504880) {
+    m *= 0.5;
+    k++;
+  }
+
+  double z = (m - 1.0) / (m + 1.0);
+  double z2 = z * z;
+
+  double p = 1.0 / 39.0;
+  p = 1.0 / 37.0 + z2 * p;
+  p = 1.0 / 35.0 + z2 * p;
+  p = 1.0 / 33.0 + z2 * p;
+  p = 1.0 / 31.0 + z2 * p;
+  p = 1.0 / 29.0 + z2 * p;
+  p = 1.0 / 27.0 + z2 * p;
+  p = 1.0 / 25.0 + z2 * p;
+  p = 1.0 / 23.0 + z2 * p;
+  p = 1.0 / 21.0 + z2 * p;
+  p = 1.0 / 19.0 + z2 * p;
+  p = 1.0 / 17.0 + z2 * p;
+  p = 1.0 / 15.0 + z2 * p;
+  p = 1.0 / 13.0 + z2 * p;
+  p = 1.0 / 11.0 + z2 * p;
+  p = 1.0 / 9.0  + z2 * p;
+  p = 1.0 / 7.0  + z2 * p;
+  p = 1.0 / 5.0  + z2 * p;
+  p = 1.0 / 3.0  + z2 * p;
+
+  double lm = 2.0 * z * (1.0 + z2 * p);
+  return ((double)k * SM_LN2_HI + lm) + (double)k * SM_LN2_LO;
 }
 
-double sin(double x) {
-  assert(0);
+static int sm_y_is_integer_class(double y)
+{
+  uint64_t uy = sm_asuint64(y) & SM_ABS_MASK;
+  int exp_bits = (int)((uy >> 52) & 0x7ff);
+  int e = exp_bits - 1023;
+
+  if (exp_bits == 0x7ff)
+    return 0;
+  if (e < 0)
+    return uy == 0 ? 2 : 0;
+  if (e > 52)
+    return 2; /* Spacing is at least 2, so representable integers are even. */
+
+  uint64_t mant = (uy & SM_FRAC_MASK) | UINT64_C(0x0010000000000000);
+  uint64_t frac_mask = (UINT64_C(1) << (52 - e)) - 1;
+  if ((mant & frac_mask) != 0)
+    return 0;
+
+  uint64_t int_lsb = (mant >> (52 - e)) & 1;
+  return int_lsb ? 1 : 2; /* 1 = odd integer, 2 = even integer. */
 }
 
-double cos(double x) {
-  assert(0);
